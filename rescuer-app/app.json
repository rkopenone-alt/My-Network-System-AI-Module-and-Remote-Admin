{
  "expo": {
    "name": "Rescuer Field App",
    "slug": "rescuer-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/official_rescuer_icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "android": {
      "package": "com.rescue.rescuer",
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/official_rescuer_icon.png",
        "backgroundColor": "#1e40af"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "usesCleartextTraffic": true
    },
    "ios": {
      "supportsTablet": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8e3880e8-4734-4691-bc3f-65beb23ed967"
      }
    },
    "owner": "tmrk"
  }
}
